# ===========================
# SUPABASE SETTINGS
# ===========================
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_ROLE=your_supabase_service_role_secret_key

# ===========================
# TELEGRAM BOT SETTINGS
# ===========================
BOT_TOKEN=your_telegram_bot_token
ADMIN_TELEGRAM_ID=your_admin_telegram_user_id

# ===========================
# RESEND EMAIL SETTINGS
# ===========================
RESEND_API_KEY=your_resend_api_key
ADMIN_EMAIL=your_admin_email_for_ott_notifications

# ===========================
# RAZORPAY SETTINGS (Live or Test keys)
# ===========================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_signature_secret

# ===========================
# SECURITY SETTINGS
# ===========================
ADMIN_API_SECRET=your_admin_api_secret_key
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
